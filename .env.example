# Copy this file to `.env` and fill in real values. `.env` is gitignored.

# --- LLM providers ---
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
HF_TOKEN=

# --- Optional: local model server ---
# OLLAMA_BASE_URL=http://localhost:11434

# --- Story2Belief settings ---
# Default LLM identifier used by src/story2belief/llm/client.py.
S2B_DEFAULT_MODEL=gpt-4o-mini

# Where to write run artifacts (overrides the path in configs/default.yaml).
# S2B_RESULTS_DIR=./results

# Logging verbosity: DEBUG | INFO | WARNING | ERROR
S2B_LOG_LEVEL=INFO
